generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  name      String
  email     String   @unique
  role      String   @default("student") // "student" or "faculty"
  xp        Int      @default(0)
  streak    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress           StudentProgress[]
  userBadges         UserBadge[]
  quizAttempts       QuizAttempt[]
  simulationProgress SimulationProgress[]
}

model Module {
  id          String   @id @default(cuid())
  moduleNo    Int
  title       String
  hours       Int
  co          String
  description String

  subtopics          Subtopic[]
  simulations        Simulation[]
  quizzes            Quiz[]
  studentProgress    StudentProgress[]
}

model Subtopic {
  id              String   @id @default(cuid())
  moduleId        String
  subtopicNo      String
  title           String
  description     String
  videoUrl        String?
  notesUrl        String?
  learningOutcome String?
  referenceUrl    String?

  module          Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  simulations     Simulation[]
  quizzes         Quiz[]
}

model Simulation {
  id              String   @id @default(cuid())
  moduleId        String
  subtopicId      String?
  title           String
  description     String
  difficulty      String
  xpReward        Int
  estimatedTime   String?
  learningOutcome String?
  frontendUrl     String?

  module          Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  subtopic        Subtopic? @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  progress        SimulationProgress[]
}

model SimulationProgress {
  id           String   @id @default(cuid())
  userId       String
  simulationId String
  completed    Boolean  @default(false)
  xpEarned     Int      @default(0)
  createdAt    DateTime @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
}

model Quiz {
  id          String   @id @default(cuid())
  moduleId    String
  subtopicId  String?
  title       String
  difficulty  String
  timeLimit   Int // in minutes
  xpReward    Int
  documentUrl String?

  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  subtopic    Subtopic? @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  questions   Question[]
  attempts    QuizAttempt[]
}

model Question {
  id            String   @id @default(cuid())
  quizId        String
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String // "A", "B", "C", "D"
  marks         Int      @default(1)
  explanation   String?
  difficulty    String?

  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id         String   @id @default(cuid())
  userId     String
  quizId     String
  score      Int      @default(0)
  totalMarks Int
  xpEarned   Int      @default(0)
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz       Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers    QuizAnswer[]
}

model QuizAnswer {
  id             String   @id @default(cuid())
  attemptId      String
  questionId     String
  selectedOption String // "A", "B", "C", "D"
  isCorrect      Boolean

  attempt        QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
}

model Flashcard {
  id        String   @id @default(cuid())
  question  String
  answer    String
  createdAt DateTime @default(now())
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String
  condition   String // "Complete Module 1", "Earn 1000 XP"

  userBadges  UserBadge[]
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  dateEarned DateTime @default(now())

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
}

model StudentProgress {
  id                 String   @id @default(cuid())
  userId             String
  moduleId           String
  completedSubtopics String[] // Array of completed subtopic IDs
  completed          Boolean  @default(false)
  updatedAt          DateTime @updatedAt

  user               User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module             Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Resource {
  id        String   @id @default(cuid())
  title     String
  type      String   // "paper" or "book"
  link      String   // Google Drive Link
  detail    String?  // Year/Semester or Edition/Author details
  createdAt DateTime @default(now())
}
